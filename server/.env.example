# RedDial — Environment Variables
# Copy this file to .env and fill in your keys.  Copy: cp .env.example .env
#
# SAFETY: RedDial only ever attacks a target you build and own, seeded with FAKE
# PII (Stripe test BIN / specimen SSN). For outbound PSTN, only dial numbers under
# your control or with written consent (TCPA). The text loopback (run_loopback /
# campaign_runner) needs NO keys at all — it runs fully offline against mocks.

# --- Twilio (outbound PSTN transport — optional; loopback needs none) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 caller ID you have VERIFIED in Twilio (verification has a delay — do it
# the night before). RedDial dials FROM this number.
VERIFIED_CALLER_ID=
# Public wss host Twilio streams media back to, e.g. your-app.ngrok.io
PUBLIC_HOST=

# --- NVIDIA Nemotron LLM (attacker brain + leak-classifier judge) ---
# NIM is OpenAI-compatible: point base_url at /v1.
NEMOTRON_LLM_URL=
NEMOTRON_LLM_API_KEY=EMPTY
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=false

# --- NVIDIA Parakeet ASR (STT, WebSocket) ---
NVIDIA_ASR_URL=

# --- Gradium (TTS) ---
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# --- Cekura (persona-pack registration + observability — optional) ---
# Without a key, cekura_integration no-ops gracefully (returns labeled stubs).
CEKURA_API_KEY=
CEKURA_BASE_URL=https://api.cekura.ai

# --- OpenAI (only used by the alternate bot-gpt.py starter) ---
OPENAI_API_KEY=

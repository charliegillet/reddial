# RedDial — Environment Variables  (copy: cp .env.example .env)
#
# SAFETY: RedDial only ever attacks a target you build and own, seeded with FAKE
# PII (Stripe test BIN / specimen SSN). For outbound PSTN, only dial numbers under
# your control or with written consent (TCPA). The OFFLINE harness (run_loopback /
# campaign_runner / efficacy_run --mode loopback) needs NONE of these — it runs
# fully offline against the mock. The vars below are for the LIVE voice path.
#
# Legend:  [REQUIRED] live voice  ·  [DIAL] only to place outbound calls  ·
#          [OPTIONAL] has a safe default / feature is optional

# ── Role & runtime ───────────────────────────────────────────────────────────
REDDIAL_ROLE=target              # target (default) | attacker | flower  — which bot bot.py runs
ENV=local                        # "local" disables the Krisp cloud audio filter; unset in cloud
REDDIAL_LOG_LEVEL=INFO           # [OPTIONAL] DEBUG|INFO|WARNING|ERROR
REDDIAL_SKIP_PREFLIGHT=          # [OPTIONAL] =1 to skip startup config validation (not recommended)
REDDIAL_FORCE_DETERMINISTIC=     # [OPTIONAL] =1 forces keyword posture even when a model is configured

# ── NVIDIA Nemotron — attacker brain + posture classifier ────────────────────
NVIDIA_ASR_URL=                  # [REQUIRED] Parakeet STT WebSocket, e.g. ws://host:8081 (no default)
NEMOTRON_LLM_URL=                # [REQUIRED] OpenAI-compatible /v1, e.g. http://host:8000/v1 (no default)
NEMOTRON_LLM_API_KEY=EMPTY       # [OPTIONAL] vLLM ignores unless --api-key was set
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super  # [OPTIONAL] served model id
NEMOTRON_ENABLE_THINKING=false   # [OPTIONAL] keep false for low-latency voice

# ── Gradium TTS (the bot's voice) ────────────────────────────────────────────
GRADIUM_API_KEY=                 # [REQUIRED] hard-required for any voice run (KeyError if missing)
GRADIUM_VOICE_ID=                # [OPTIONAL] has a built-in default voice

# ── Twilio — OUTBOUND PSTN (attacker dialing) ────────────────────────────────
TWILIO_ACCOUNT_SID=              # [DIAL]
TWILIO_AUTH_TOKEN=               # [DIAL]
VERIFIED_CALLER_ID=              # [DIAL] E.164 caller ID VERIFIED in Twilio — RedDial dials FROM this
PUBLIC_HOST=                     # [DIAL] public wss host Twilio streams back to, e.g. your-app.ngrok.io
REDDIAL_WS_PATH=/ws              # [OPTIONAL] media stream path = the runner's telephony route (/ws)

# ── Outbound dialing SAFETY GATE (enforced in code; FAILS CLOSED) ────────────
# Dialing is REFUSED unless ALL hold: kill-switch on + E.164 + allowlisted + per-call consent.
REDDIAL_DIALING_ENABLED=         # [DIAL] set to 1/true/yes to permit any dialing (default OFF)
REDDIAL_DIAL_ALLOWLIST=          # [DIAL] comma-separated E.164 numbers you own / have consent for (+1...)
REDDIAL_MAX_CALLS=50             # [OPTIONAL] per-process hard call cap (CallGuard); unset => 50
REDDIAL_MIN_CALL_INTERVAL_S=0    # [OPTIONAL] minimum seconds between calls (rate limit)

# ── Cekura (persona-pack registration + observability) ───────────────────────
# OPTIONAL: without a key every Cekura call no-ops gracefully (run `make cekura-check`).
CEKURA_API_KEY=                  # [OPTIONAL] (or X_CEKURA_API_KEY)
X_CEKURA_API_KEY=                # [OPTIONAL] alternate header name for the same key
CEKURA_BASE_URL=https://api.cekura.ai
CEKURA_OBSERVABILITY_PATH=/observability/send-calls   # [OPTIONAL] override if Cekura changes it
CEKURA_HEALTH_PATH=/test_framework/v1/scenarios        # [OPTIONAL] used by check_connection()

# ── OpenAI — ONLY for REDDIAL_ROLE=flower's GPT variant (bot-gpt.py) ─────────
OPENAI_API_KEY=                  # [OPTIONAL] not needed for target/attacker (Nemotron)
OPENAI_MODEL=                    # [OPTIONAL]

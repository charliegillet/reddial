# RedDial — Environment Variables  (copy: cp .env.example .env)
#
# SAFETY: RedDial only ever attacks a target you build and own, seeded with FAKE
# PII (Stripe test BIN / specimen SSN). For outbound PSTN, only dial numbers under
# your control or with written consent (TCPA). The OFFLINE harness (run_loopback /
# campaign_runner / efficacy_run --mode loopback) needs NONE of these — it runs
# fully offline against the mock. The vars below are for the LIVE voice path.
#
# Legend:  [REQUIRED] live voice  ·  [DIAL] only to place outbound calls  ·
#          [OPTIONAL] has a safe default / feature is optional
#
# NOTE ON FORMATTING: comments live on their OWN line ABOVE each key. Do NOT put
# an inline comment after a blank value (e.g. `KEY=  # note`) — python-dotenv
# leaks the comment text as the value ("# note"), which is a TRUTHY string that
# defeats `os.getenv(KEY) or DEFAULT` fallbacks.

# ── Role & runtime ───────────────────────────────────────────────────────────
# target (default) | attacker | flower  — which bot bot.py runs
REDDIAL_ROLE=target
# "local" disables the Krisp cloud audio filter; unset in cloud
ENV=local
# [OPTIONAL] DEBUG|INFO|WARNING|ERROR
REDDIAL_LOG_LEVEL=INFO
# [OPTIONAL] =1 to skip startup config validation (not recommended)
REDDIAL_SKIP_PREFLIGHT=
# [OPTIONAL] =1 forces keyword posture even when a model is configured
REDDIAL_FORCE_DETERMINISTIC=

# ── NVIDIA Nemotron — attacker brain + posture classifier ────────────────────
# [REQUIRED] Parakeet STT WebSocket, e.g. ws://host:8081 (no default)
NVIDIA_ASR_URL=
# [REQUIRED] OpenAI-compatible /v1, e.g. http://host:8000/v1 (no default)
NEMOTRON_LLM_URL=
# [OPTIONAL] vLLM ignores unless --api-key was set
NEMOTRON_LLM_API_KEY=EMPTY
# [OPTIONAL] served model id
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
# [OPTIONAL] keep false for low-latency voice
NEMOTRON_ENABLE_THINKING=false

# ── Gradium TTS (the bot's voice) ────────────────────────────────────────────
# [REQUIRED] hard-required for any voice run (KeyError if missing)
GRADIUM_API_KEY=
# [OPTIONAL] uncomment to override the built-in default voice; leaving it commented
# (vs. set-empty) keeps the per-bot default — a sourced empty "" falls back anyway
# GRADIUM_VOICE_ID=

# ── Twilio — OUTBOUND PSTN (attacker dialing) ────────────────────────────────
# [DIAL]
TWILIO_ACCOUNT_SID=
# [DIAL]
TWILIO_AUTH_TOKEN=
# [DIAL] E.164 caller ID VERIFIED in Twilio — RedDial dials FROM this
VERIFIED_CALLER_ID=
# [DIAL] public wss host Twilio streams back to, e.g. your-app.ngrok.io
PUBLIC_HOST=
# [OPTIONAL] media stream path = the runner's telephony route (/ws)
REDDIAL_WS_PATH=/ws

# ── Outbound dialing SAFETY GATE (enforced in code; FAILS CLOSED) ────────────
# Dialing is REFUSED unless ALL hold: kill-switch on + E.164 + allowlisted + per-call consent.
# [DIAL] set to 1/true/yes to permit any dialing (default OFF)
REDDIAL_DIALING_ENABLED=
# [DIAL] comma-separated E.164 numbers you own / have consent for (+1...)
REDDIAL_DIAL_ALLOWLIST=
# [OPTIONAL] per-process hard call cap (CallGuard); unset => 50
REDDIAL_MAX_CALLS=50
# [OPTIONAL] minimum seconds between calls (rate limit)
REDDIAL_MIN_CALL_INTERVAL_S=0

# ── Cekura (persona-pack registration + observability) ───────────────────────
# OPTIONAL: without a key every Cekura call no-ops gracefully (run `make cekura-check`).
# [OPTIONAL] (or X_CEKURA_API_KEY)
CEKURA_API_KEY=
# [OPTIONAL] alternate header name for the same key
X_CEKURA_API_KEY=
CEKURA_BASE_URL=https://api.cekura.ai
# [OPTIONAL] override if Cekura changes it
CEKURA_OBSERVABILITY_PATH=/observability/v1/observe/
# [OPTIONAL] override if Cekura changes it
CEKURA_SCENARIOS_PATH=/test_framework/v1/scenarios/
# [OPTIONAL] used by check_connection()
CEKURA_HEALTH_PATH=/test_framework/v1/scenarios
# Cekura agent (provision once via POST /test_framework/v1/aiagents/). Required
# for scenario create (needs `personality`) AND observability ingest (needs `agent`).
# [OPTIONAL] Cekura agent integer id (from aiagents create)
CEKURA_AGENT_ID=
# [OPTIONAL] agent's enabled_personalities[0] (int)
CEKURA_PERSONALITY_ID=
# [OPTIONAL] alt to CEKURA_AGENT_ID for observability ingest
CEKURA_ASSISTANT_ID=

# ── OpenAI — ONLY for REDDIAL_ROLE=flower's GPT variant (bot-gpt.py) ─────────
# [OPTIONAL] not needed for target/attacker (Nemotron)
OPENAI_API_KEY=
# [OPTIONAL]
OPENAI_MODEL=
